# Total Form Fitness — environment variables
# Copy to .env.local for local dev and set the same keys in Vercel.
# NEVER commit .env.local. Secrets are denied from git (CLAUDE.md §3).

# --- Supabase (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-only — never exposed to the browser) ---
# Used by trusted server actions (e.g. resolving the coach link at signup).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Public origin, used for auth email redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
